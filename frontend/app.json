{
  "expo": {
    "name": "sitePilot",
    "slug": "sitepilot",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F97316"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.sitepilot.app" },
    "android": {
      "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#F97316" },
      "package": "com.sitepilot.app"
    },
    "web": { "favicon": "./assets/favicon.png", "bundler": "metro" },
    "plugins": [
      ["expo-camera",       { "cameraPermission": "Allow sitePilot to access your camera." }],
      ["expo-image-picker", { "photosPermission": "Allow sitePilot to access your photos." }]
    ]
  }
}